# Loopers Main Application (PWA) - Public Environment Variables

# Backend API Endpoint URL
# In development, leave blank to use the Vite config proxy, or specify the local API host (http://localhost:5000)
# In production, set to your live backend domain (e.g. https://loopers-backend.herokuapp.com)
VITE_API_URL=https://loopers-backend.herokuapp.com

# UPI Payment Merchant Config
VITE_UPI_ID=9391472578@ybl
VITE_UPI_NAME="Loopers Quick Commerce"
