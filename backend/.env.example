# Loopers Backend - Environment Variables Configuration

# Server Connection Port
PORT=5000

# MongoDB Connection String (Atlas or Local Instance)
MONGO_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/loopers?retryWrites=true&w=majority"

# JWT Token Cryptographic Secret (Minimum 32 characters recommended for production)
JWT_SECRET=supersecretloopers2026

# Node Execution Environment (production, development, or test)
NODE_ENV=production

# Cloudinary Media Storage Configurations
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Web Push Notification Cryptographic Keys (VAPID)
# Generate via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Database Seeding Trigger (Set to "true" to seed default categories/collections)
SEED_DATABASE=true

# Merchant UPI Integration Configuration
UPI_ID=9391472578@ybl
UPI_NAME="Loopers Quick Commerce"

# CORS Allowed Origins (Comma-separated list of production client URLs)
ALLOWED_ORIGINS="https://loopers.vercel.app"
